# Picser 環境變數設定範本
# 複製此檔案為 .env.local 並填入您的實際值

# GitHub Token（需要 repo 權限）
# 取得方式：https://github.com/settings/tokens/new
GITHUB_TOKEN=your_github_token_here

# GitHub 倉庫擁有者（您的 GitHub 用戶名）
GITHUB_OWNER=kinai9661

# GitHub 倉庫名稱
GITHUB_REPO=picser

# GitHub 分支（預設為 main）
GITHUB_BRANCH=main

# NextAuth.js 設定（可選，用於身份驗證）
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# GitHub OAuth 應用程式設定（可選，用於 GitHub 登入）
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
